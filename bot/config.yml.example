# RATScanner Discord Bot - Configuration
# Copy this to config.yml and fill in your values.

discord:
  token: "YOUR_BOT_TOKEN_HERE"
  # Optional: restrict to a specific guild for faster slash command registration
  # guild_id: "123456789012345678"
  # Allow users to install the bot to their account (works in any server with external apps)
  allow_user_install: false
  # Allow the bot to receive commands in DMs
  allow_dms: false
  # Allow the bot to work in servers it hasn't been added to (via user install)
  allow_external_guilds: false

virustotal:
  api_key: "YOUR_VT_API_KEY_HERE"
  enabled: true
  # Upload unknown files to VT for analysis (set false for hash-only lookups)
  # Note: when true, submitted files are uploaded to VirusTotal's public database
  upload_unknown: false

malwarebazaar:
  enabled: true
  auth_key: "YOUR_MB_AUTH_KEY_HERE"
  # Free auth key at https://bazaar.abuse.ch/account/ (login required)
  # Auto-upload flagged malware samples to MalwareBazaar (only after detection)
  upload_flagged: true

hybrid_analysis:
  api_key: "YOUR_HA_API_KEY_HERE"
  enabled: true
  # Free API key at https://www.hybrid-analysis.com/signup

scanner:
  java_path: "java"
  max_file_size_mb: 50
  scan_timeout_seconds: 300
  max_concurrent_scans: 3
  cooldown_seconds: 30
  auto_delete_webhooks: true
  auto_cleanup_days: 30
  # Save scanned files to disk (default: false for safety)
  save_samples: false
  # Route URL downloads through Tor (recommended for safety)
  require_tor_for_urls: true
  # Tor SOCKS5 proxy address (default Tor Expert Bundle port)
  # If using Tor Browser instead, change to port 9150
  tor_proxy: "socks5://127.0.0.1:9050"

yara:
  enabled: true
  rules_dir: "rules"
